{
  "name": "@webmobix/file-uploader",
  "version": "0.0.1",
  "description": "A web component for selecting one or more files for uploading. Has preview for images included.",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/file-uploader/file-uploader.esm.js",
  "exports": {
    ".": {
      "import": "./dist/file-uploader/file-uploader.esm.js",
      "require": "./dist/file-uploader/file-uploader.cjs.js",
      "types": "./dist/types/index.d.ts"
    },
    "./file-uploader": {
      "import": "./dist/components/wmx-file-uploader.js",
      "types": "./dist/components/wmx-file-uploader.d.ts"
    },
    "./dist/components/*": {
      "import": "./dist/components/*",
      "types": "./dist/components/*.d.ts"
    },
    "./dist/components": {
      "import": "./dist/components/index.js",
      "types": "./dist/components/index.d.ts"
    },
    "./dist/*": {
      "import": "./dist/*",
      "types": "./dist/*.d.ts"
    },
    "./loader": {
      "import": "./loader/index.js",
      "require": "./loader/index.cjs",
      "types": "./loader/index.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stenciljs/component-starter.git"
  },
  "files": [
    "dist/",
    "loader/"
  ],
  "scripts": {
    "build": "stencil build",
    "start": "stencil build --dev --watch --serve",
    "test": "stencil-test --prod",
    "test:watch": "stencil-test --prod --watch",
    "generate": "stencil generate"
  },
  "devDependencies": {
    "@stencil/core": "^4.27.1 || ^5.0.0-0",
    "@stencil/react-output-target": "^1.5.3",
    "@stencil/vitest": "^1.8.3",
    "@types/node": "^22.13.5",
    "@vitest/browser-playwright": "^4.0.0",
    "playwright": "^1.52.0",
    "vitest": "^4.0.0"
  },
  "license": "MIT"
}
